    # ========================================================================
    FINANCIAL_DATA = {
        "袟邪褉邪斜芯褌薪邪褟 锌谢邪褌邪",
    }
    
    # ========================================================================
    # 7. 袦袗袩袩袠袧袚: 褌懈锌 袩袛薪 -> 泻邪褌械谐芯褉懈褟
    # ========================================================================
    PD_TO_CATEGORY = {}
    
    for pd_type in COMMON_PD:
        PD_TO_CATEGORY[pd_type] = "袨斜褘褔薪褘械 锌械褉褋芯薪邪谢褜薪褘械 写邪薪薪褘械"
    
