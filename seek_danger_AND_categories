    # ========================================================================
    # 8. 袨小袧袨袙袧袨袡 笑袠袣袥
    # ========================================================================
    for idx, row in df.iterrows():
        found_pdns_str = row["袧邪泄写械薪薪褘械 袩袛薪"]
        
        if found_pdns_str == "袧械褌 薪懈泻邪泻懈褏 薪邪褉褍褕械薪懈泄":
            df.at[idx, "袣邪褌械谐芯褉懈懈"] = "袧械褌 薪邪褉褍褕械薪懈泄"
            continue
        
        category_counts = defaultdict(int)
        
        for item in found_pdns_str.split(","):
            item = item.strip()
            if not item:
                continue
            
            # 袠小袩袪袗袙袥袝袧袨: 写芯斜邪胁谢械薪褘 谢邪褌懈薪褋泻懈械 斜褍泻胁褘 A-Za-z
            match = re.match(r'^([A-Za-z袗-携邪-褟\s:]+)\((\d+)\)$', item)
            if match:
                pd_type = match.group(1).strip()
                count = int(match.group(2))
                
                category = PD_TO_CATEGORY.get(pd_type)
                if category:
                    category_counts[category] += count
                else:
                    # 袩褉芯斜褍械屑 薪邪泄褌懈 斜械蟹 褍褔褢褌邪 褉械谐懈褋褌褉邪
                    pd_type_lower = pd_type.lower()
                    found = False
                    for key in PD_TO_CATEGORY.keys():
                        if key.lower() == pd_type_lower:
                            category = PD_TO_CATEGORY[key]
                            category_counts[category] += count
                            found = True
                            break
                    
                    if not found:
                        category_counts["袧械懈蟹胁械褋褌薪邪褟 泻邪褌械谐芯褉懈褟"] += count
        
        if category_counts:
            result_parts = [f"{category}({count})" for category, count in sorted(category_counts.items())]
